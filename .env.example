# Start-Apps — пример окружения. Скопируй в .env и подставь свои значения.
# .env в git не коммитим (см. .gitignore).

# --- секреты ---
SECRET_KEY=change-me-to-a-long-random-string

# --- базы ---
DATABASE_URL=postgresql+psycopg://sa:sa@postgres:5432/startapps
REDIS_URL=redis://redis:6379/0

# --- режим ---
SA_ENV=dev

# --- frontend ---
VITE_SA_API=http://localhost:8000
